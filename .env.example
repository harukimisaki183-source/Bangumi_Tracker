# ========================================
# Bangumi Tracker — Environment Variables
# ========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=bangumi_tracker

# ---- JWT ----
# Generate strong random strings for production
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# ---- SMTP (QQ Mail) ----
# Use your QQ email SMTP authorization code (not your QQ password)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-authorization-code
SMTP_FROM=your-email@qq.com

# ---- MinIO (Object Storage) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=bangumi

# ---- CORS ----
CORS_ORIGIN=http://localhost
